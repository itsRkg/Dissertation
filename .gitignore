# ============================================================
#  Dissertation .gitignore - keep CODE in git; keep DATA,
#  RESULTS, model WEIGHTS, LOGS and SECRETS out.
# ============================================================

# ---- Data (2 GB; uploaded to Kaggle as a Dataset, never to git) ----
data/

# ---- Experiment outputs: results, model weights, logs ----
experiments/results/
experiments/saved_models/
experiments/logs/
experiments/experimentation_notebooks/checkpoints/
experiments/experimentation_notebooks/logs/
experiments/experimentation_notebooks/*.csv
*.pt
*.pth
*.ckpt
*.npz

# ---- Kaggle scratch ----
/kaggle/
kaggle_working/

# ---- Python / Jupyter ----
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# ---- Secrets / credentials (NEVER commit) ----
kaggle.json
.env
.env.*
*.pem
*.key
id_rsa*
.netrc
*credentials*

# ---- Editor / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db

# NOTE: .ipynb files ARE tracked (needed for the Kaggle pull); clear their
# outputs before committing (Jupyter "Clear All Outputs" or nbstripout).
